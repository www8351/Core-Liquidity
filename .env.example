# ── Core (required) ───────────────────────────────────────────────────
TELEGRAM_TOKEN=your-telegram-bot-token
CHAT_ID=your-chat-id
ANTHROPIC_API_KEY=your-anthropic-key
TWELVEDATA_API_KEY=your-twelvedata-key   # fallback feed (Docker/Linux)

# ── MetaTrader5 (Windows primary feed + live execution) ───────────────
# MT5_LOGIN=12345678
# MT5_PASSWORD=...
# MT5_SERVER=Broker-Server
# MT5_SYMBOL=XAUUSD            # broker-specific (e.g. XAUUSDm, XAUUSD.r)
# TWELVEDATA_SYMBOL=XAU/USD

# ── Quarterly-Theory strategy ─────────────────────────────────────────
# RISK_PCT=0.01               # fraction of balance risked per trade (1%)
# SL_BUFFER=0.5               # extra price beyond the Judas range for the stop
# STRATEGY_POLL_MIN=5         # how often (minutes) to evaluate the setup
# ACCOUNT_BALANCE=10000       # used for sizing when MT5 balance is unavailable
# SESSION_START_HOUR=2        # NY-hour trading window start (London open)
# SESSION_END_HOUR=16         # NY-hour trading window end (NY close)
# QT_TRUE_DAY_OPEN_HOUR=18    # True Day open hour in NY time (Daye standard)

# ── Dashboard (web monitor) ───────────────────────────────────────────
# Disabled until DASHBOARD_TOKEN is set. Token guards every route
# (?token=... or X-Token header), compared constant-time.
# DASHBOARD_TOKEN=choose-a-long-random-string
# DASHBOARD_HOST=0.0.0.0          # 127.0.0.1 = localhost only
# DASHBOARD_PORT=8080
# DASHBOARD_REFRESH_SEC=5         # browser poll interval
# View at: http://<host>:8080/?token=YOUR_TOKEN

# ── SAFETY: live order placement ──────────────────────────────────────
# LIVE_TRADING defaults to false. While false the bot computes + sends signals
# to Telegram but places NO MT5 orders (dry-run). Set true ONLY after you have
# watched dry-run signals and trust them. Real money is at risk when true.
# LIVE_TRADING=false

# ── Misc ──────────────────────────────────────────────────────────────
# TZ=Asia/Jerusalem
# LOG_LEVEL=INFO
